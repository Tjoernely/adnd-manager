{
  "name": "dnd-manager-server",
  "version": "2.0.0",
  "description": "AD&D Campaign Manager - Express + PostgreSQL backend",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "migrate": "node migrate.js",
    "import-spells": "node scripts/import-spells.js",
    "import:spells": "node ../scripts/import-spells.mjs",
    "import:items": "node ../scripts/import-magical-items.mjs",
    "import:s3items": "node ../scripts/import-s3-items.mjs",
    "import:items-all": "node ../scripts/import-item-descriptions.mjs",
    "import:monsters": "node ../scripts/import-monsters.mjs",
    "recalc:hp": "node recalculate-monster-hp.mjs",
