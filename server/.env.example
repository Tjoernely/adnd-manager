# ── Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adnd_manager
DB_USER=adnd
DB_PASSWORD=change_me_in_production

# ── Auth ───────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_in_production

# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# ── App URL (for invite links) ─────────────────────────────────────
APP_URL=http://localhost:3000

# ── AI Generation ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Image Generation (optional) ────────────────────────────────────
# Replicate API key — enables ControlNet SDXL terrain rendering
REPLICATE_API_KEY=r8_...
# OpenAI API key — enables DALL-E fallback image generation
OPENAI_API_KEY=sk-...
# Set to "true" to test sketch flow without any API keys
CONTROLNET_MOCK=false
