# ── Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adnd_manager
DB_USER=adnd
DB_PASSWORD=change_me_in_production

# ── Auth ───────────────────────────────────────────────────────────
# Must be at least 32 characters. Server refuses to start in production
# if missing or the old placeholder is used. Generate with e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change_me_to_a_long_random_secret_in_production

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
# NODE_ENV controls helmet/rate-limit strictness and the JWT_SECRET guard.
# Set to 'production' on the live server.
NODE_ENV=production

# ── CORS allowlist ─────────────────────────────────────────────────
# Comma-separated list of allowed Origins. Leave commented to fall back
# to localhost:5173 + http(s)://158.180.63.20 (the built-in defaults).
# Once HTTPS lands, restrict to the https:// origin only.
# CORS_ORIGINS=https://158.180.63.20,https://your-domain.example

# ── App URL (for invite links) ─────────────────────────────────────
APP_URL=http://localhost:3000

# ── Signup notifications (optional) ────────────────────────────────
# If set, a fire-and-forget Discord webhook fires on each new registration:
#   "New RealmKeep signup: {username} ({email}) — pending approval"
# Leave unset to disable — no notification is sent, and a webhook failure
# never affects registration. (Could be swapped for an email provider later.)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── AI Generation ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Image Generation — OpenAI (active) ─────────────────────────────
OPENAI_API_KEY=sk-...

# ── Image Generation — Google AI ────────────────────────────────────
# Used by sketch-to-map rendering AND server-side character/NPC portraits
# (POST /api/ai/character-image, gemini-3.1-flash-image).
# GOOGLE_AI_API_KEY=...

# Per-user daily cap on generated images (character-image route).
# Unset → default 20. Counter resets at day rollover (ai_image_usage table).
# IMAGE_DAILY_CAP=20

# ── Legacy (no longer used) ──────────────────────────────────────────
# REPLICATE_API_KEY=r8_...
